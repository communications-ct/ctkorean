---
import { t, getLocalizedPath, getAlternateLocale } from '../i18n/utils';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const altLocale = getAlternateLocale(locale as 'ko' | 'en');
const homePath = getLocalizedPath('', locale as 'ko' | 'en');

// Load urgent announcements (within 7 days)
let urgentAnnouncements: { title: string; body: string; date: string }[] = [];
try {
  const annPath = path.resolve('public/data/announcements.json');
  if (fs.existsSync(annPath)) {
    const all = JSON.parse(fs.readFileSync(annPath, 'utf-8'));
    const now = Date.now();
    const SEVEN_DAYS = 7 * 24 * 60 * 60 * 1000;
    urgentAnnouncements = all.filter((a: any) => {
      const isUrgent = a.urgent === 1 || a.urgent === '1' || a.urgent === 'y';
      const age = now - new Date(a.date).getTime();
      return isUrgent && age >= 0 && age <= SEVEN_DAYS;
    });
  }
} catch (_e) { /* ignore */ }

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const pagePathRaw = Astro.url.pathname
  .replace(new RegExp(`^${basePath}`), '')
  .replace(/^\/(ko|en)\/?/, '');
const altPath = getLocalizedPath(pagePathRaw, altLocale);

const isNews = Astro.url.pathname.includes('/news');

const navItems = [
  { label: t(locale, 'nav.home'), href: homePath, active: !isNews },
  { label: t(locale, 'nav.about'), href: `${homePath}#about` },
  { label: t(locale, 'nav.priests'), href: `${homePath}#priests` },
  { label: t(locale, 'nav.mass'), href: `${homePath}#mass` },
  { label: t(locale, 'nav.directions'), href: `${homePath}#directions` },
  { label: t(locale, 'nav.news'), href: getLocalizedPath('news', locale as 'ko' | 'en'), active: isNews },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={homePath} class="flex items-center gap-2 shrink-0" aria-label={t(locale, 'site.title')}>
        <!-- Sacred Heart Logo -->
        <svg class="w-8 h-8 text-red-700 shrink-0" viewBox="0 0 100 100" fill="none" aria-hidden="true">
          <path d="M50 90C50 90 10 60 10 35C10 20 22 10 35 10C42 10 48 14 50 18C52 14 58 10 65 10C78 10 90 20 90 35C90 60 50 90 50 90Z" fill="currentColor"/>
          <path d="M46 8h8v20h20v8H54v35h-8V36H26v-8h20z" fill="white"/>
        </svg>
        {locale === 'ko' ? (
          <div class="flex flex-col leading-tight min-w-0">
            <span class="text-xs sm:text-sm lg:text-base font-bold text-gray-900 truncate">예수성심 천주교 커네티컷 성당</span>
            <span class="hidden sm:block text-[10px] lg:text-xs text-gray-500">Sacred Heart of Jesus Korean Catholic Parish</span>
          </div>
        ) : (
          <div class="flex flex-col leading-tight min-w-0">
            <span class="text-xs sm:text-sm lg:text-base font-bold text-gray-900 truncate">Sacred Heart of Jesus Korean Catholic Parish</span>
            <span class="hidden sm:block text-[10px] lg:text-xs text-gray-500">예수성심 천주교 커네티컷 성당</span>
          </div>
        )}
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-5">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors',
              item.active ? 'text-primary-500' : 'text-gray-700 hover:text-primary-500',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={altPath}
          class="ml-1 px-3 py-1.5 text-sm border border-primary-500 text-primary-500 rounded-md hover:bg-primary-500 hover:text-white transition-colors"
        >
          {t(locale, 'nav.language')}
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-700 hover:text-primary-500 transition-colors"
        aria-label={t(locale, 'nav.menu')}
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M6 18L18 6"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'py-3 border-b border-gray-50 transition-colors',
            item.active ? 'text-primary-500 font-medium' : 'text-gray-700 hover:text-primary-500',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href={altPath} class="py-3 text-primary-500 font-medium">
        {t(locale, 'nav.language')}
      </a>
    </div>
  </nav>
</header>

{urgentAnnouncements.length > 0 && (
  <div class="bg-red-600 text-white">
    {urgentAnnouncements.map(ann => (
      <div class="max-w-6xl mx-auto px-4 py-2 flex items-center gap-3 text-sm">
        <span class="shrink-0 px-2 py-0.5 bg-white text-red-600 text-xs font-bold rounded">
          {locale === 'ko' ? '긴급' : 'URGENT'}
        </span>
        <span class="font-medium truncate">{ann.title}</span>
        {ann.body && (
          <span class="hidden sm:inline text-red-100 truncate">— {ann.body.split('\n')[0]}</span>
        )}
      </div>
    ))}
  </div>
)}

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close mobile menu when clicking a hash link
  menu?.querySelectorAll('a[href*="#"]').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
