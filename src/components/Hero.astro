---
import { t, getLocalizedPath } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative bg-gradient-to-b from-primary-50 to-white py-16 md:py-24">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <img
      src={`${base}/header.png`}
      alt={t(locale, 'hero.title')}
      class="mx-auto max-h-24 sm:max-h-32 md:max-h-40 mb-8"
    />
    <p class="text-lg sm:text-xl md:text-2xl text-gray-600 font-light mb-10">
      {t(locale, 'hero.subtitle')}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={getLocalizedPath('news', locale as 'ko' | 'en')} class="btn-primary">
        {t(locale, 'hero.cta.news')}
      </a>
      <a href="#mass" class="btn-secondary">
        {t(locale, 'hero.cta.mass')}
      </a>
    </div>
  </div>
</section>
