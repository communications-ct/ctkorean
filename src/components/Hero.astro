---
import { t, getLocalizedPath } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroImages = [
  { src: `${base}/00.jpg`, alt: t(locale, 'hero.photoAlt', { n: 1 }) },
  { src: `${base}/01.jpg`, alt: t(locale, 'hero.photoAlt', { n: 2 }) },
  { src: `${base}/02.webp`, alt: t(locale, 'hero.photoAlt', { n: 3 }) },
  { src: `${base}/03.webp`, alt: t(locale, 'hero.photoAlt', { n: 4 }) },
  { src: `${base}/04.jpg`, alt: t(locale, 'hero.photoAlt', { n: 5 }) },
];
---

<section class="relative h-[60vh] md:h-[80vh] overflow-hidden">
  <!-- Slides -->
  {heroImages.map((img, i) => (
    <div
      class:list={[
        'hero-slide absolute inset-0 transition-opacity duration-1000',
        i === 0 ? 'opacity-100' : 'opacity-0',
      ]}
    >
      <img
        src={img.src}
        alt={img.alt}
        class="w-full h-full object-cover"
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    </div>
  ))}

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Content -->
  <div class="relative z-10 flex items-center justify-center h-full text-white text-center px-4">
    <div class="max-w-4xl">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-6 drop-shadow-lg">
        {t(locale, 'hero.title')}
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl font-light mb-10 drop-shadow">
        {t(locale, 'hero.subtitle')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('news', locale as 'ko' | 'en')} class="btn-primary">
          {t(locale, 'hero.cta.news')}
        </a>
        <a
          href="#mass"
          class="btn-secondary !text-white !border-white hover:!bg-white hover:!text-primary-500"
        >
          {t(locale, 'hero.cta.mass')}
        </a>
      </div>
    </div>
  </div>

  <!-- Slide Indicators -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex gap-2">
    {heroImages.map((_, i) => (
      <button
        class:list={[
          'hero-dot w-3 h-3 rounded-full bg-white transition-opacity duration-300',
          i === 0 ? 'opacity-100' : 'opacity-50',
        ]}
        data-index={i}
        aria-label={t(locale, 'hero.slide', { n: i + 1 })}
      />
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current]?.classList.replace('opacity-100', 'opacity-0');
    dots[current]?.classList.remove('opacity-100');
    dots[current]?.classList.add('opacity-50');

    current = ((index % slides.length) + slides.length) % slides.length;

    slides[current]?.classList.replace('opacity-0', 'opacity-100');
    dots[current]?.classList.remove('opacity-50');
    dots[current]?.classList.add('opacity-100');
  }

  function startAutoplay() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(Number((dot as HTMLElement).dataset.index));
      startAutoplay();
    });
  });

  startAutoplay();
</script>
