---
import { t, formatDate } from '../i18n/utils';

interface Bulletin {
  date: string;
  title: string;
  type: string;
  fileUrl: string;
  previewUrl: string;
}

interface Props {
  bulletins: Bulletin[];
  locale: string;
}

const { bulletins, locale } = Astro.props;
const site = 'https://communications-ct.github.io';

const sorted = [...bulletins].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noBulletins')}</p>
) : (
  <div class="space-y-3">
    {sorted.map(bul => {
      const fullUrl = `${site}${bul.fileUrl}`;
      const gviewUrl = `https://docs.google.com/gview?url=${encodeURIComponent(fullUrl)}&embedded=true`;
      return (
        <details class="card group bulletin-details">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none hover:bg-gray-50 transition-colors">
            <div class="flex items-center gap-3 min-w-0">
              <svg class="w-6 h-6 text-red-500 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/>
              </svg>
              <span class="font-medium text-gray-900 truncate">{bul.title}</span>
            </div>
            <div class="flex items-center gap-2 shrink-0 ml-4">
              <span class="text-sm text-gray-400">{formatDate(bul.date, locale)}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </summary>
          <div class="border-t border-gray-100">
            <div class="flex items-center justify-end gap-3 px-4 py-2 bg-gray-50">
              <a
                href={bul.fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-500 text-sm font-medium hover:underline"
              >
                {locale === 'ko' ? '새 창에서 열기' : 'Open in new tab'} &rarr;
              </a>
            </div>
            {/* Desktop: 브라우저 내장 PDF 뷰어 (페이지 넘김/줌 지원) */}
            <iframe
              class="w-full bg-white bulletin-iframe hidden"
              style="height: 80vh;"
              data-pdf={bul.fileUrl}
              data-gview={gviewUrl}
              src="about:blank"
              title={bul.title}
            ></iframe>
          </div>
        </details>
      );
    })}
  </div>
)}

<script>
  const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

  document.querySelectorAll('.bulletin-details').forEach(details => {
    details.addEventListener('toggle', () => {
      const iframe = details.querySelector('.bulletin-iframe') as HTMLIFrameElement;
      if (!iframe) return;
      iframe.classList.remove('hidden');
      if ((details as HTMLDetailsElement).open) {
        // Desktop: 로컬 PDF 직접 (내장 뷰어로 전체 페이지 스크롤/줌)
        // Mobile: Google Docs Viewer (모바일 PDF 렌더링 지원)
        const url = isMobile ? (iframe.dataset.gview || '') : (iframe.dataset.pdf || '');
        if (url && !iframe.src.endsWith(url)) {
          iframe.src = url;
        }
      } else {
        iframe.src = 'about:blank';
      }
    });
  });
</script>
