---
import { t, formatDate } from '../i18n/utils';

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <div class="space-y-3">
    {sorted.map(album => (
      <details class="card group">
        <summary class="flex items-center gap-4 p-4 cursor-pointer list-none hover:bg-gray-50 transition-colors">
          <img
            src={album.thumbUrl}
            alt={album.title}
            class="w-16 h-12 object-cover rounded shrink-0"
            loading="lazy"
          />
          <div class="flex-1 min-w-0">
            <span class="font-medium text-gray-900 truncate block">{album.title}</span>
            <span class="text-sm text-gray-400">{formatDate(album.date, locale)}</span>
          </div>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="border-t border-gray-100 p-4">
          <div class="flex justify-center mb-4">
            <img
              src={album.thumbUrl}
              alt={album.title}
              class="max-w-full max-h-[50vh] object-contain rounded-lg"
              loading="lazy"
            />
          </div>
          <div class="text-center">
            <a
              href={`https://drive.google.com/drive/folders/${album.albumId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500 text-white text-sm font-medium rounded-lg hover:bg-primary-600 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              {locale === 'ko' ? '전체 사진 보기 (Google Drive)' : 'View all photos (Google Drive)'}
            </a>
          </div>
        </div>
      </details>
    ))}
  </div>
)}
