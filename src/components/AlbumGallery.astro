---
import { t, formatDate } from '../i18n/utils';

interface Photo {
  id: string;
  name: string;
}

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
  photos?: Photo[];
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <>
    <div class="space-y-3">
      {sorted.map((album, idx) => (
        <button
          type="button"
          class="card w-full flex items-center gap-4 p-4 cursor-pointer hover:bg-gray-50 transition-colors text-left album-open-btn"
          data-album-idx={idx}
        >
          <img
            src={album.thumbUrl}
            alt={album.title}
            class="w-16 h-12 object-cover rounded shrink-0"
            loading="lazy"
          />
          <div class="flex-1 min-w-0">
            <span class="font-medium text-gray-900 truncate block">{album.title}</span>
            <span class="text-sm text-gray-400">
              {formatDate(album.date, locale)}
              {album.photos && album.photos.length > 0 && (
                <span class="ml-1 text-gray-300">· {album.photos.length}{locale === 'ko' ? '장' : ' photos'}</span>
              )}
            </span>
          </div>
          <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      ))}
    </div>

    <!-- Album Gallery Modal -->
    <div id="album-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto bg-gray-50">
      <!-- Sticky header -->
      <div class="sticky top-0 z-20 flex items-center justify-between px-4 py-3 bg-white shadow-sm">
        <div class="flex items-center gap-2 min-w-0">
          <h3 id="album-modal-title" class="font-bold text-gray-900 text-sm truncate"></h3>
          <span id="album-modal-count" class="text-xs text-gray-400 shrink-0"></span>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <a id="album-modal-drive" href="#" target="_blank" rel="noopener noreferrer"
            class="text-primary-500 text-sm font-medium hover:underline hidden sm:inline">
            Google Drive
          </a>
          <button type="button" id="album-modal-close"
            class="flex items-center gap-1 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            {locale === 'ko' ? '닫기' : 'Close'}
          </button>
        </div>
      </div>

      <!-- Photo grid -->
      <div id="album-grid" class="max-w-6xl mx-auto px-3 py-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 sm:gap-3"></div>
    </div>

    <!-- Lightbox -->
    <div id="album-lightbox" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/90">
      <button type="button" id="lb-close" class="absolute top-4 right-4 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <button type="button" id="lb-prev" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <button type="button" id="lb-next" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
      <img id="lb-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain" />
      <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/80 text-sm bg-black/50 px-3 py-1 rounded-full"></div>
    </div>
  </>
)}

<script define:vars={{ albumsData: sorted.map(a => ({ title: a.title, albumId: a.albumId, photos: a.photos || [] })) }}>
  const modal = document.getElementById('album-modal');
  const titleEl = document.getElementById('album-modal-title');
  const countEl = document.getElementById('album-modal-count');
  const driveLink = document.getElementById('album-modal-drive');
  const closeBtn = document.getElementById('album-modal-close');
  const grid = document.getElementById('album-grid');

  const lightbox = document.getElementById('album-lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCounter = document.getElementById('lb-counter');
  const lbClose = document.getElementById('lb-close');
  const lbPrev = document.getElementById('lb-prev');
  const lbNext = document.getElementById('lb-next');

  let currentPhotos = [];
  let currentIdx = 0;

  function imgUrl(fileId, w) {
    return 'https://lh3.googleusercontent.com/d/' + fileId + '=w' + w;
  }

  function openAlbum(albumIdx) {
    const album = albumsData[albumIdx];
    if (!album || !modal || !grid) return;

    titleEl.textContent = album.title;
    countEl.textContent = album.photos.length > 0 ? '(' + album.photos.length + ')' : '';
    driveLink.href = 'https://drive.google.com/drive/folders/' + album.albumId;

    grid.innerHTML = '';
    currentPhotos = album.photos;

    if (currentPhotos.length === 0) {
      grid.innerHTML = '<p class="col-span-full text-center text-gray-400 py-12">사진이 아직 없습니다.</p>';
    } else {
      currentPhotos.forEach(function(photo, idx) {
        var div = document.createElement('div');
        div.className = 'aspect-square overflow-hidden rounded-lg bg-gray-200 cursor-pointer group';
        var img = document.createElement('img');
        img.src = imgUrl(photo.id, 400);
        img.alt = photo.name;
        img.className = 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300';
        img.loading = 'lazy';
        div.appendChild(img);
        div.addEventListener('click', function() { openLightbox(idx); });
        grid.appendChild(div);
      });
    }

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function openLightbox(idx) {
    if (!lightbox || !lbImg) return;
    currentIdx = idx;
    updateLightbox();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
  }

  function updateLightbox() {
    if (!currentPhotos[currentIdx]) return;
    lbImg.src = imgUrl(currentPhotos[currentIdx].id, 1200);
    lbImg.alt = currentPhotos[currentIdx].name;
    lbCounter.textContent = (currentIdx + 1) + ' / ' + currentPhotos.length;
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lbImg.src = '';
  }

  function closeAlbum() {
    if (!modal) return;
    closeLightbox();
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.album-open-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(btn.dataset.albumIdx, 10);
      openAlbum(idx);
    });
  });

  closeBtn && closeBtn.addEventListener('click', closeAlbum);
  lbClose && lbClose.addEventListener('click', closeLightbox);
  lbPrev && lbPrev.addEventListener('click', function() { currentIdx = (currentIdx - 1 + currentPhotos.length) % currentPhotos.length; updateLightbox(); });
  lbNext && lbNext.addEventListener('click', function() { currentIdx = (currentIdx + 1) % currentPhotos.length; updateLightbox(); });

  document.addEventListener('keydown', function(e) {
    if (lightbox && !lightbox.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + currentPhotos.length) % currentPhotos.length; updateLightbox(); }
      if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % currentPhotos.length; updateLightbox(); }
    } else if (modal && !modal.classList.contains('hidden')) {
      if (e.key === 'Escape') closeAlbum();
    }
  });
</script>
