---
import { t, formatDate } from '../i18n/utils';

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <div class="space-y-3">
    {sorted.map(album => (
      <details class="card group album-details">
        <summary class="flex items-center gap-4 p-4 cursor-pointer list-none hover:bg-gray-50 transition-colors">
          <img
            src={album.thumbUrl}
            alt={album.title}
            class="w-16 h-12 object-cover rounded shrink-0"
            loading="lazy"
          />
          <div class="flex-1 min-w-0">
            <span class="font-medium text-gray-900 truncate block">{album.title}</span>
            <span class="text-sm text-gray-400">{formatDate(album.date, locale)}</span>
          </div>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="border-t border-gray-100">
          <div class="flex items-center justify-end gap-3 px-4 py-2 bg-gray-50">
            <a
              href={`https://drive.google.com/drive/folders/${album.albumId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary-500 text-sm font-medium hover:underline"
            >
              {locale === 'ko' ? '새 창에서 열기' : 'Open in new tab'} &rarr;
            </a>
          </div>
          <iframe
            class="w-full bg-white album-iframe"
            style="height: 70vh;"
            data-src={`https://drive.google.com/embeddedfolderview?id=${album.albumId}#grid`}
            src=""
            title={album.title}
          ></iframe>
        </div>
      </details>
    ))}
  </div>
)}

<script>
  document.querySelectorAll('.album-details').forEach(details => {
    details.addEventListener('toggle', () => {
      const iframe = details.querySelector('.album-iframe') as HTMLIFrameElement;
      if (!iframe) return;
      if ((details as HTMLDetailsElement).open) {
        if (!iframe.src || iframe.src === '' || iframe.src === 'about:blank') {
          iframe.src = iframe.dataset.src || '';
        }
      } else {
        iframe.src = '';
      }
    });
  });
</script>
