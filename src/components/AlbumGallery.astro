---
import { t, formatDate } from '../i18n/utils';

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
  photoCount?: number;
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <>
    <div class="space-y-3">
      {sorted.map(album => (
        <details class="card group album-details" data-album-id={album.albumId}>
          <summary class="flex items-center gap-4 p-4 cursor-pointer list-none hover:bg-gray-50 transition-colors">
            <img
              src={album.thumbUrl}
              alt={album.title}
              class="w-16 h-12 object-cover rounded shrink-0"
              loading="lazy"
            />
            <div class="flex-1 min-w-0">
              <span class="font-medium text-gray-900 truncate block">{album.title}</span>
              <span class="text-sm text-gray-400">
                {formatDate(album.date, locale)}
                {album.photoCount && album.photoCount > 0 && (
                  <span class="ml-1 text-gray-300">· {album.photoCount}{locale === 'ko' ? '장' : ' photos'}</span>
                )}
              </span>
            </div>
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="border-t border-gray-100 p-4">
            <!-- Loading placeholder -->
            <div class="album-loading flex items-center justify-center py-8">
              <div class="w-6 h-6 border-2 border-primary-500 border-t-transparent rounded-full animate-spin"></div>
              <span class="ml-2 text-gray-400 text-sm">{locale === 'ko' ? '사진을 불러오는 중...' : 'Loading...'}</span>
            </div>
            <!-- Photo grid (filled by JS) -->
            <div class="album-grid hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 sm:gap-3"></div>
            <!-- Drive link -->
            <div class="mt-3 text-center">
              <a
                href={`https://drive.google.com/drive/folders/${album.albumId}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-500 text-sm font-medium hover:underline"
              >
                {locale === 'ko' ? 'Google Drive에서 보기' : 'View on Google Drive'} &rarr;
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Lightbox (shared across all albums) -->
    <div id="album-lightbox" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/90">
      <button type="button" id="lb-close" class="absolute top-4 right-4 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <button type="button" id="lb-prev" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <button type="button" id="lb-next" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
      <img id="lb-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain" />
      <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/80 text-sm bg-black/50 px-3 py-1 rounded-full"></div>
    </div>
  </>
)}

<script define:vars={{ basePath }}>
  var photoCache = {};
  var lbPhotos = [];
  var lbIdx = 0;

  var lightbox = document.getElementById('album-lightbox');
  var lbImg = document.getElementById('lb-img');
  var lbCounter = document.getElementById('lb-counter');

  function imgUrl(id, w) { return 'https://lh3.googleusercontent.com/d/' + id + '=w' + w; }

  function openLightbox(photos, idx) {
    lbPhotos = photos;
    lbIdx = idx;
    updateLightbox();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox() {
    if (!lbPhotos[lbIdx]) return;
    lbImg.src = imgUrl(lbPhotos[lbIdx].id, 1200);
    lbImg.alt = lbPhotos[lbIdx].name;
    lbCounter.textContent = (lbIdx + 1) + ' / ' + lbPhotos.length;
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  function renderGrid(gridEl, photos) {
    photos.forEach(function(photo, idx) {
      var div = document.createElement('div');
      div.className = 'aspect-square overflow-hidden rounded-lg bg-gray-200 cursor-pointer group';
      var img = document.createElement('img');
      img.src = imgUrl(photo.id, 400);
      img.alt = photo.name;
      img.className = 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300';
      img.loading = 'lazy';
      div.appendChild(img);
      div.addEventListener('click', function() { openLightbox(photos, idx); });
      gridEl.appendChild(div);
    });
  }

  document.querySelectorAll('.album-details').forEach(function(details) {
    var loaded = false;

    details.addEventListener('toggle', function() {
      if (!details.open || loaded) return;
      loaded = true;

      var albumId = details.dataset.albumId;
      var loadingEl = details.querySelector('.album-loading');
      var gridEl = details.querySelector('.album-grid');

      // Check cache
      if (photoCache[albumId]) {
        loadingEl.classList.add('hidden');
        renderGrid(gridEl, photoCache[albumId]);
        gridEl.classList.remove('hidden');
        return;
      }

      // Fetch per-album JSON
      fetch(basePath + '/data/albums/' + albumId + '.json')
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(photos) {
          photoCache[albumId] = photos;
          loadingEl.classList.add('hidden');
          if (photos.length === 0) {
            gridEl.innerHTML = '<p class="col-span-full text-center text-gray-400 py-4">사진이 아직 없습니다.</p>';
          } else {
            renderGrid(gridEl, photos);
          }
          gridEl.classList.remove('hidden');
        })
        .catch(function() {
          loadingEl.classList.add('hidden');
          gridEl.innerHTML = '<p class="col-span-full text-center text-gray-400 py-4">사진을 불러올 수 없습니다.</p>';
          gridEl.classList.remove('hidden');
        });
    });
  });

  // Lightbox controls
  document.getElementById('lb-close').addEventListener('click', closeLightbox);
  document.getElementById('lb-prev').addEventListener('click', function() {
    lbIdx = (lbIdx - 1 + lbPhotos.length) % lbPhotos.length; updateLightbox();
  });
  document.getElementById('lb-next').addEventListener('click', function() {
    lbIdx = (lbIdx + 1) % lbPhotos.length; updateLightbox();
  });
  document.addEventListener('keydown', function(e) {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') { lbIdx = (lbIdx - 1 + lbPhotos.length) % lbPhotos.length; updateLightbox(); }
    if (e.key === 'ArrowRight') { lbIdx = (lbIdx + 1) % lbPhotos.length; updateLightbox(); }
  });
</script>
