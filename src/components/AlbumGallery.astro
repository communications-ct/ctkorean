---
import { t, formatDate } from '../i18n/utils';

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <>
    <div class="space-y-3">
      {sorted.map(album => (
        <button
          type="button"
          class="card w-full flex items-center gap-4 p-4 cursor-pointer hover:bg-gray-50 transition-colors text-left album-open-btn"
          data-album-id={album.albumId}
          data-title={album.title}
          data-thumb={album.thumbUrl}
        >
          <img
            src={album.thumbUrl}
            alt={album.title}
            class="w-16 h-12 object-cover rounded shrink-0"
            loading="lazy"
          />
          <div class="flex-1 min-w-0">
            <span class="font-medium text-gray-900 truncate block">{album.title}</span>
            <span class="text-sm text-gray-400">{formatDate(album.date, locale)}</span>
          </div>
          <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      ))}
    </div>

    <!-- Album Modal -->
    <div id="album-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto">
      <div class="absolute inset-0 bg-black/70" id="album-modal-backdrop"></div>
      <div class="relative z-10 min-h-full bg-white">
        <!-- Sticky header with close button -->
        <div class="sticky top-0 z-20 flex items-center justify-between px-4 py-3 bg-white shadow">
          <h3 id="album-modal-title" class="font-bold text-gray-900 text-sm truncate mr-4"></h3>
          <div class="flex items-center gap-3 shrink-0">
            <a id="album-modal-drive" href="#" target="_blank" rel="noopener noreferrer"
              class="text-primary-500 text-sm font-medium hover:underline">
              {locale === 'ko' ? 'Google Drive' : 'Google Drive'}
            </a>
            <button type="button" id="album-modal-close"
              class="flex items-center gap-1 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
              {locale === 'ko' ? '닫기' : 'Close'}
            </button>
          </div>
        </div>
        <!-- Content: Drive embed iframe -->
        <iframe
          id="album-modal-iframe"
          class="w-full bg-white"
          style="height: calc(100vh - 52px);"
          src="about:blank"
          title="Album Viewer"
        ></iframe>
      </div>
    </div>
  </>
)}

<script>
  const modal = document.getElementById('album-modal');
  const iframe = document.getElementById('album-modal-iframe') as HTMLIFrameElement;
  const titleEl = document.getElementById('album-modal-title');
  const driveLink = document.getElementById('album-modal-drive') as HTMLAnchorElement;
  const closeBtn = document.getElementById('album-modal-close');
  const backdrop = document.getElementById('album-modal-backdrop');

  function openAlbum(albumId: string, title: string) {
    if (!modal || !iframe || !titleEl || !driveLink) return;
    const driveUrl = `https://drive.google.com/drive/folders/${albumId}`;
    const embedUrl = `https://drive.google.com/embeddedfolderview?id=${albumId}#grid`;
    titleEl.textContent = title;
    driveLink.href = driveUrl;
    iframe.src = embedUrl;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeAlbum() {
    if (!modal || !iframe) return;
    modal.classList.add('hidden');
    iframe.src = 'about:blank';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.album-open-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      openAlbum(el.dataset.albumId || '', el.dataset.title || '');
    });
  });

  closeBtn?.addEventListener('click', closeAlbum);
  backdrop?.addEventListener('click', closeAlbum);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAlbum(); });
</script>
