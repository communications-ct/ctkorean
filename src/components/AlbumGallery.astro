---
import { t, formatDate } from '../i18n/utils';

interface Album {
  date: string;
  title: string;
  albumId: string;
  thumbUrl: string;
}

interface Props {
  albums: Album[];
  locale: string;
}

const { albums, locale } = Astro.props;

const sorted = [...albums].sort((a, b) => b.date.localeCompare(a.date));
---

{sorted.length === 0 ? (
  <p class="text-center text-gray-400 py-8 col-span-full">{t(locale, 'news.noAlbums')}</p>
) : (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {sorted.map(album => (
      <a
        href={`https://drive.google.com/drive/folders/${album.albumId}`}
        target="_blank"
        rel="noopener noreferrer"
        class="card group block"
      >
        <div class="aspect-[4/3] overflow-hidden bg-gray-100">
          <img
            src={album.thumbUrl}
            alt={album.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>
        <div class="p-4">
          <h3 class="font-bold text-gray-900 text-sm group-hover:text-primary-500 transition-colors">
            {album.title}
          </h3>
          <p class="text-gray-400 text-xs mt-1">{formatDate(album.date, locale)}</p>
        </div>
      </a>
    ))}
  </div>
)}
