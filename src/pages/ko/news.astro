---
import fs from 'node:fs';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementList from '../../components/AnnouncementList.astro';
import BulletinList from '../../components/BulletinList.astro';
import AlbumGallery from '../../components/AlbumGallery.astro';
import { t } from '../../i18n/utils';

const locale = 'ko';

function readJson(filename: string): any[] {
  try {
    return JSON.parse(fs.readFileSync(`public/data/${filename}`, 'utf8'));
  } catch {
    return [];
  }
}

const announcements = readJson('announcements.json');
const bulletins = readJson('bulletins.json');
const albums = readJson('albums.json');
---

<BaseLayout locale={locale} title={`${t(locale, 'news.title')} - ${t(locale, 'site.title')}`}>
  <main id="main-content" class="flex-1">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <h1 class="section-title">{t(locale, 'news.title')}</h1>

      <section id="ann" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.announcements')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.announcements.desc')}</p>
        <AnnouncementList announcements={announcements} locale={locale} />
      </section>

      <section id="bul" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.bulletins')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.bulletins.desc')}</p>
        <BulletinList bulletins={bulletins} locale={locale} />
      </section>

      <section id="alb" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.albums')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.albums.desc')}</p>
        <AlbumGallery albums={albums} locale={locale} />
      </section>

      <section id="history">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'history.title')}</h2>
        <p class="text-gray-500 text-sm mb-8">1978년부터 이어온 커네티컷 한인 가톨릭 공동체의 발자취</p>

        <div class="relative">
          {/* Vertical timeline line */}
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-primary-200"></div>

          {[
            { year: '1978년 7월', title: '커네티컷 한인 공동체의 시작', text: 'Norwich Mohegan Park에서 50여 명의 신자들과 한국 사목 경험이 있는 미국인 O\'Brien 신부님이 만남.' },
            { year: '1978년 8월', title: '첫 미사 봉헌', text: 'New Haven의 St. Mary 성당에서 70여 명의 신자들이 O\'Brien 신부님 집전으로 첫 미사를 봉헌.' },
            { year: '1979~1991년', title: '성장과 퇴보', text: 'O\'Brien 신부님 발령 이후 평신도 지도자 권 베드로가 1986년 종신 부제품을 받고 공동체를 이끌게 됨. West Haven의 St. Lawrence 성당으로 이전. 한인 사제의 부재로 미사를 봉헌하지 못하는 상황까지 이르게 됨.' },
            { year: '1992년 8월', title: '변희선 안셀모 신부님 부임', text: 'Hartford 대교구 Cronin 대주교님께서 변희선 안셀모 신부님을 커네티컷 한인 천주교회 초대 주임신부로 임명.' },
            { year: '1994년', title: '조규덕 마태오 신부님 미사 집전', text: '변 안셀모 신부님 이임 후, Long Island Great Neck 성당 주임이셨던 조규덕 마태오 신부님께서 매주 토요일 저녁 St. Lawrence 성당에서 미사를 집전해 주심.' },
            { year: '1994년 4월', title: '안승길 로베르토 신부님 부임', text: '모든 신자들의 간절한 기도와 노력, Hartford 교구의 요청으로 원주 교구의 안승길 로베르토 신부님을 주임신부로 모심.' },
            { year: '1996~1997년', title: '류해욱 요셉 신부님 미사 집전', text: '안 로베르토 신부님의 갑작스러운 귀국 이후, Boston에서 학업 중이던 류해욱 요셉 신부님께서 St. Lawrence 성당에서 미사를 집전해 주심.' },
            { year: '1997~1999년', title: '김성호 베네딕토 신부님 미사 집전', text: '류 요셉 신부님 귀국 후, Columbia 대학에서 학업 중이던 김성호 베네딕토 신부님께서 공동체를 이끌어 주심.' },
            { year: '1999년 8월', title: '이상일 시몬 신부님 부임', text: '전 서강대학교 총장이셨던 이상일 시몬 신부님 부임. Hartford 교구로부터 본당 주임 사제직 승인을 추진하시고, 공동체 회관 건립을 위한 본당 발전 위원회를 구성하심.' },
            { year: '1999년 9월', title: 'Hartford 구역 미사 분리', text: '회관 건립 시까지 Hartford 주일 미사를 New Haven 지역과 분리하여 Manchester Chenny Hall에서 첫 미사 거행.' },
            { year: '2000년 12월', title: '선교의 날 행사', text: 'Rosazza 주교님을 모시고 Chenny Hall에서 대희년 맞이 선교의 날 행사 거행. 주교님께서 Sacred Heart 성당에서 Hartford 구역 미사를 봉헌할 수 있도록 주선해 주심.' },
            { year: '2001년', title: '본당 이전 및 통합', text: 'St. Lawrence 성당과 Sacred Heart 성당 두 곳에서 봉헌하던 미사를 Sacred Heart 성당(Wethersfield)으로 최종 통합. 이후 커네티컷 전체 신자가 함께 미사를 봉헌하게 됨.' },
            { year: '2002년 8월', title: '박명근 클레멘스 신부님 부임', text: 'Hartford 교구의 초청으로 서울 교구의 박명근 클레멘스 신부님 주임신부로 부임.' },
            { year: '2003년 1월', title: '박명숙 데레사 수녀님 파견', text: '한국 순교 복자 수녀회에서 박명숙 데레사 수녀님 파견.' },
            { year: '2003년', title: 'Rosazza 주교님 · Colton 신부님 미사 집전', text: '박명근 클레멘스 신부님의 갑작스러운 귀국 이후, Rosazza 주교님께서 직접 미사를 집전해 주시며 후임 신부님 파견을 위해 힘써 주심.' },
            { year: '2004년 10월', title: '전교 회관(사제관) 구입', text: '범 공동체 모금 운동을 통해 모든 교우분들의 기도와 희생, 적극적인 참여로 창립 26년 만에 처음으로 사제관과 전교 회관을 마련함.' },
            { year: '2004년 10월', title: '전영준 바오로 신부님 부임', text: '서울 대교구의 전영준 바오로 신부님께서 Hartford 대교구의 공식 초청으로 주임신부로 부임.' },
            { year: '2008년 3월', title: '김훈겸 세례자 요한 신부님 부임', text: '' },
            { year: '2013년 2월', title: '이철 니콜라오 신부님 부임', text: '' },
            { year: '2017년 11월', title: '이계천 세례자 요한 신부님 부임', text: '' },
            { year: '2019년 1월', title: '준본당 승격', text: '\'예수성심 천주교 커네티컷 성당(Sacred Heart of Jesus Korean Catholic Parish)\' 이라는 이름으로 준본당으로 승격되고 독립적인 법인체로 설립됨.' },
            { year: '2019년 3월', title: '준본당 승격 기념 미사', text: '준본당 승격 기념 미사 봉헌.' },
            { year: '2022년', title: '이상선 요셉 신부님 부임', text: '서울 대교구 소속 이상선 요셉 신부님을 제11대 주임신부로 모심. 사목회, 전례부, 레지오 마리애, 성심회 등 다양한 소공동체가 활발히 활동 중.' },
            { year: '2024년 12월', title: '다문화 성탄 음악회', text: 'Multicultural Christmas Concert 개최.' },
            { year: '2025년 1월', title: '설 미사 및 본당 봉사자 이·취임식', text: '설 미사 및 합동 위령 미사 봉헌, 본당 봉사자 이·취임식 거행.' },
            { year: '2025년 3월', title: 'Coyne 대주교님 본당 방문', text: 'Coyne 대주교님 본당 방문.' },
          ].map(item => (
            <div class="relative pl-10 pb-8 last:pb-0">
              <div class="absolute left-4 -translate-x-1/2 w-3 h-3 rounded-full bg-primary-500 border-2 border-white shadow mt-1.5"></div>
              <span class="inline-block px-3 py-1 text-sm font-bold text-primary-600 bg-primary-50 rounded-full mb-1">{item.year}</span>
              <h3 class="text-lg font-semibold text-gray-900 mb-1">{item.title}</h3>
              {item.text && <p class="text-gray-600 leading-relaxed">{item.text}</p>}
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
