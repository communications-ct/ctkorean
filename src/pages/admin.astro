---
/**
 * Admin page — redirects to GAS admin panel.
 * Authentication is handled by GAS (ADMIN_PASSWORD in Script Properties).
 * This page is just a convenience entry point.
 */
const gasAdminUrl = 'https://script.google.com/macros/s/AKfycbysgcyhqJWBNeUrIRBNwT7vqU2dEQc-ZzE4YNYZtjSf8vddUFxr9TrWVI2DU1D6Dpxa-g/exec?mode=admin';
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>관리자 패널</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="refresh" content={`0;url=${gasAdminUrl}`} />
  <style>
    body { font-family: 'Noto Sans KR', system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f5f5f5; color: #333; }
    .card { text-align: center; padding: 40px; background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    a { color: #3A66B0; text-decoration: none; font-weight: 600; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="card">
    <p>관리자 패널로 이동 중...</p>
    <p><a href={gasAdminUrl}>자동 이동되지 않으면 여기를 클릭하세요</a></p>
  </div>
</body>
</html>
