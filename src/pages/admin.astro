---
/**
 * Admin page — embeds GAS admin panel in iframe.
 * Authentication is handled by GAS (ADMIN_PASSWORD in Script Properties).
 * XFrameOptionsMode.ALLOWALL is set in GAS to allow iframe embedding.
 */
const gasAdminUrl = 'https://script.google.com/macros/s/AKfycbysgcyhqJWBNeUrIRBNwT7vqU2dEQc-ZzE4YNYZtjSf8vddUFxr9TrWVI2DU1D6Dpxa-g/exec?mode=admin';
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>관리자 패널</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Noto Sans KR', system-ui, sans-serif; height: 100vh; display: flex; flex-direction: column; }
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 16px; background: #3A66B0; color: #fff; font-size: 14px;
    }
    .topbar a { color: #fff; text-decoration: none; opacity: 0.8; font-size: 13px; }
    .topbar a:hover { opacity: 1; text-decoration: underline; }
    iframe { flex: 1; width: 100%; border: none; }
    .fallback { text-align: center; padding: 40px; color: #666; }
    .fallback a { color: #3A66B0; font-weight: 600; }
  </style>
</head>
<body>
  <div class="topbar">
    <span>성당 관리자 패널</span>
    <a href={gasAdminUrl} target="_blank" rel="noopener">새 창에서 열기 &rarr;</a>
  </div>
  <iframe src={gasAdminUrl} title="관리자 패널" allow="clipboard-write"></iframe>
  <noscript>
    <div class="fallback">
      <p><a href={gasAdminUrl}>관리자 패널 열기</a></p>
    </div>
  </noscript>
</body>
</html>
