---
import fs from 'node:fs';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementList from '../../components/AnnouncementList.astro';
import BulletinList from '../../components/BulletinList.astro';
import AlbumGallery from '../../components/AlbumGallery.astro';
import { t } from '../../i18n/utils';

const locale = 'en';

function readJson(filename: string): any[] {
  try {
    return JSON.parse(fs.readFileSync(`public/data/${filename}`, 'utf8'));
  } catch {
    return [];
  }
}

const announcements = readJson('announcements.json');
const bulletins = readJson('bulletins.json');
const albums = readJson('albums.json');
---

<BaseLayout locale={locale} title={`${t(locale, 'news.title')} - ${t(locale, 'site.title')}`}>
  <main id="main-content" class="flex-1">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <h1 class="section-title">{t(locale, 'news.title')}</h1>

      <section id="ann" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.announcements')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.announcements.desc')}</p>
        <AnnouncementList announcements={announcements} locale={locale} />
      </section>

      <section id="bul" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.bulletins')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.bulletins.desc')}</p>
        <BulletinList bulletins={bulletins} locale={locale} />
      </section>

      <section id="alb" class="mb-16">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'news.albums')}</h2>
        <p class="text-gray-500 text-sm mb-6">{t(locale, 'news.albums.desc')}</p>
        <AlbumGallery albums={albums} locale={locale} />
      </section>

      <section id="history">
        <h2 class="text-2xl font-bold text-primary-700 mb-2">{t(locale, 'history.title')}</h2>
        <p class="text-gray-500 text-sm mb-8">The journey of the Korean Catholic community in Connecticut since 1978</p>

        <div class="relative">
          {/* Vertical timeline line */}
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-primary-200"></div>

          {[
            { year: 'Mar 2025', title: 'Archbishop Coyne\'s Parish Visit', text: 'Archbishop Coyne visited the parish.' },
            { year: 'Jan 2025', title: 'Lunar New Year Mass & Ministry Installation', text: 'Lunar New Year Mass with joint memorial Mass, and ministry officers installation ceremony.' },
            { year: 'Dec 2024', title: 'Multicultural Christmas Concert', text: 'Multicultural Christmas Concert held.' },
            { year: '2022', title: 'Fr. Joseph Sangsun Lee Appointed', text: 'Fr. Joseph Sangsun Lee from the Archdiocese of Seoul was appointed as the 11th pastor. Various small communities including the Pastoral Council, Liturgy Committee, Legion of Mary, and Sacred Heart Society are actively serving.' },
            { year: 'Mar 2019', title: 'Quasi-Parish Inauguration Mass', text: 'Celebration Mass for the quasi-parish elevation.' },
            { year: 'Jan 2019', title: 'Elevated to Quasi-Parish', text: 'Established as "Sacred Heart of Jesus Korean Catholic Parish" and elevated to quasi-parish status with independent incorporation under the Archdiocese of Hartford.' },
            { year: 'Nov 2017', title: 'Fr. John the Baptist Kyechun Lee Appointed', text: '' },
            { year: 'Feb 2013', title: 'Fr. Nicholas Chul Lee Appointed', text: '' },
            { year: 'Mar 2008', title: 'Fr. John the Baptist Hoonkyum Kim Appointed', text: '' },
            { year: 'Oct 2004', title: 'Fr. Paul Youngjun Jeon Appointed', text: 'Fr. Paul Youngjun Jeon from the Archdiocese of Seoul was appointed as pastor at the official invitation of the Hartford Archdiocese.' },
            { year: 'Oct 2004', title: 'Parish Hall (Rectory) Purchased', text: 'Through a community-wide fundraising campaign, the parish acquired its first owned building — a rectory and mission hall — 26 years after its founding.' },
            { year: '2003', title: 'Bishop Rosazza & Fr. Colton Celebrate Mass', text: 'After Fr. Park\'s sudden return to Korea, Bishop Rosazza personally celebrated Mass and worked to arrange a successor. Fr. Colton of Sacred Heart Church also celebrated Mass during this period.' },
            { year: 'Jan 2003', title: 'Sr. Theresa Myungsuk Park Assigned', text: 'Sr. Theresa Myungsuk Park was assigned by the Korean Martyrs Sisters.' },
            { year: 'Aug 2002', title: 'Fr. Clement Myunggeun Park Appointed', text: 'Fr. Clement Myunggeun Park from the Archdiocese of Seoul was appointed as pastor at the invitation of the Hartford Archdiocese.' },
            { year: '2001', title: 'Parish Relocation and Unification', text: 'Masses at both St. Lawrence Church and Sacred Heart Church were unified at Sacred Heart Church in Wethersfield. All Connecticut faithful began worshiping together.' },
            { year: 'Dec 2000', title: 'Mission Day Celebration', text: 'A Great Jubilee Mission Day celebration was held at Chenny Hall with Bishop Rosazza. The Bishop arranged for the Hartford area Mass to be held at Sacred Heart Church.' },
            { year: 'Sep 1999', title: 'Hartford Area Mass Separated', text: 'Hartford Sunday Mass was separated from the New Haven area, with the first Mass celebrated at Chenny Hall in Manchester.' },
            { year: 'Aug 1999', title: 'Fr. Simon Sangil Lee Appointed', text: 'Fr. Simon Sangil Lee, former president of Sogang University, was appointed. He pursued official pastor recognition from the Hartford Archdiocese and established a parish development committee for a community hall.' },
            { year: '1997–1999', title: 'Fr. Benedict Sungho Kim Celebrates Mass', text: 'After Fr. Ryu\'s return to Korea, Fr. Benedict Sungho Kim, studying at Columbia University, led the community.' },
            { year: '1996–1997', title: 'Fr. Joseph Haewook Ryu Celebrates Mass', text: 'After Fr. Ahn\'s sudden return to Korea, Fr. Joseph Haewook Ryu, studying in Boston, celebrated Mass at St. Lawrence Church.' },
            { year: 'Apr 1994', title: 'Fr. Roberto Seungkil Ahn Appointed', text: 'Through the prayers and efforts of the faithful and at the request of the Hartford Archdiocese, Fr. Roberto Seungkil Ahn from the Diocese of Wonju was appointed as pastor.' },
            { year: '1994', title: 'Fr. Matthew Kyuduk Cho Celebrates Mass', text: 'After Fr. Byun\'s departure, Fr. Matthew Kyuduk Cho, pastor of Great Neck parish on Long Island, celebrated Saturday evening Mass at St. Lawrence Church.' },
            { year: 'Aug 1992', title: 'Fr. Anselm Heesun Byun Appointed', text: 'Archbishop Cronin of the Archdiocese of Hartford appointed Fr. Anselm Heesun Byun as the first pastor of the Korean Catholic Church of Connecticut.' },
            { year: '1979–1991', title: 'Growth and Challenges', text: 'After Fr. O\'Brien\'s reassignment, lay leader Peter Kwon was ordained as a permanent deacon in 1986 and led the community. The community relocated to St. Lawrence Church in West Haven. Due to the absence of a Korean priest, the community faced periods without Mass.' },
            { year: 'Aug 1978', title: 'First Mass Celebrated', text: 'About 70 faithful celebrated the first Mass at St. Mary Church in New Haven, presided by Fr. O\'Brien.' },
            { year: 'Jul 1978', title: 'The Beginning of the Connecticut Korean Community', text: 'About 50 faithful gathered with Fr. O\'Brien, an American priest with pastoral experience in Korea, at Mohegan Park in Norwich.' },
          ].map(item => (
            <div class="relative pl-10 pb-8 last:pb-0">
              <div class="absolute left-4 -translate-x-1/2 w-3 h-3 rounded-full bg-primary-500 border-2 border-white shadow mt-1.5"></div>
              <span class="inline-block px-3 py-1 text-sm font-bold text-primary-600 bg-primary-50 rounded-full mb-1">{item.year}</span>
              <h3 class="text-lg font-semibold text-gray-900 mb-1">{item.title}</h3>
              {item.text && <p class="text-gray-600 leading-relaxed">{item.text}</p>}
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
