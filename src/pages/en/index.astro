---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import PriestCard from '../../components/PriestCard.astro';
import MassSchedule from '../../components/MassSchedule.astro';
import MapSection from '../../components/MapSection.astro';
import { t, ordinal } from '../../i18n/utils';
import { priests } from '../../data/priests';

const locale = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPriest = priests[0];
const formerPriests = priests.slice(1);

function genLabel(n: number): string {
  return t(locale, 'priests.generation', { n: ordinal(n) });
}
---

<BaseLayout locale={locale}>
  <main id="main-content">
    <Hero locale={locale} />

    <!-- About -->
    <section id="about" class="py-20">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="section-title">{t(locale, 'about.title')}</h2>
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div class="rounded-lg overflow-hidden shadow-md">
            <img
              src={`${base}/01.jpg`}
              alt={t(locale, 'about.title')}
              class="w-full h-72 md:h-80 object-cover"
            />
          </div>
          <div>
            <p class="text-lg text-gray-600 leading-relaxed mb-4">
              {t(locale, 'about.description')}
            </p>
            <p class="text-lg text-gray-600 leading-relaxed">
              {t(locale, 'about.description2')}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- History Timeline -->
    <section class="pb-20">
      <div class="max-w-6xl mx-auto px-4">
        <h3 class="text-2xl font-bold text-center text-gray-900 mb-10">{t(locale, 'history.title')}</h3>
        <div class="relative max-w-3xl mx-auto">
          {/* Vertical line */}
          <div class="absolute left-4 sm:left-1/2 sm:-translate-x-px top-0 bottom-0 w-0.5 bg-primary-200"></div>

          {[
            { year: '1978', text: 'First Mass celebrated for the Korean Catholic community in Connecticut' },
            { year: '1992', text: 'Officially recognized as a Korean Catholic Community' },
            { year: '2001', text: 'Relocated to current home in Wethersfield, CT' },
            { year: '2019', text: 'Elevated to Quasi-Parish under the Archdiocese of Hartford' },
            { year: '2022', text: '11th Pastor Fr. Joseph Sangsun Lee (Archdiocese of Seoul) appointed' },
          ].map((item, idx) => (
            <div class:list={[
              'relative flex items-start mb-8 last:mb-0',
              'sm:even:flex-row-reverse'
            ]}>
              {/* Dot */}
              <div class="absolute left-4 sm:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-primary-500 border-2 border-white shadow mt-1.5"></div>
              {/* Content */}
              <div class:list={[
                'ml-10 sm:ml-0 sm:w-[calc(50%-2rem)]',
                idx % 2 === 0 ? 'sm:pr-4 sm:text-right' : 'sm:pl-4 sm:text-left'
              ]}>
                <span class="inline-block px-3 py-1 text-sm font-bold text-primary-600 bg-primary-50 rounded-full mb-1">{item.year}</span>
                <p class="text-gray-700 leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Priests -->
    <section id="priests" class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="section-title">{t(locale, 'priests.title')}</h2>

        <!-- Current Pastor -->
        <div class="mb-12">
          <PriestCard
            name={`Fr. ${currentPriest.nameEn}`}
            baptismalName={currentPriest.baptismalNameEn}
            generationLabel={genLabel(currentPriest.generation)}
            tenure={`${currentPriest.tenureStart} ~ ${t(locale, 'priests.present')}`}
            image={currentPriest.image}
            highlight={true}
            currentLabel={t(locale, 'priests.current')}
          />
        </div>

        <!-- Former Pastors -->
        <h3 class="text-lg font-bold text-gray-700 text-center mb-8">
          {t(locale, 'priests.former')}
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
          {formerPriests.map(priest => (
            <PriestCard
              name={`Fr. ${priest.nameEn}`}
              baptismalName={priest.baptismalNameEn}
              generationLabel={genLabel(priest.generation)}
              tenure={`${priest.tenureStart} ~ ${priest.tenureEnd}`}
              image={priest.image}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Mass Schedule -->
    <MassSchedule locale={locale} />

    <!-- Directions & Map -->
    <MapSection locale={locale} />
  </main>
</BaseLayout>
