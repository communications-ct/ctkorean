---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <script is:inline define:vars={{ base }}>
    window.location.replace(base + '/ko/');
  </script>
  <meta http-equiv="refresh" content={`0;url=${base}/ko/`} />
</head>
<body></body>
</html>
